# LoopGuard 部署配置
# 复制此文件为 .env 并填写实际值

# === MySQL ===
MYSQL_ROOT_PASSWORD=change-me-to-a-strong-password
MYSQL_DATABASE=loopguard

# === LoopGuard ===

# 前端 nginx 对外暴露端口（宿主机映射，容器内固定 80）
# 用户访问 http://宿主机IP:此端口，nginx 再把 /api 反代到 backend:8080
LOOPGUARD_HTTP_PORT=80

# MySQL 连接字符串（DSN 格式）
# 用户名:密码@tcp(主机:端口)/数据库名?charset=utf8mb4&parseTime=True&loc=Local
LOOPGUARD_DB_DSN=root:change-me-to-a-strong-password@tcp(mysql:3306)/loopguard?charset=utf8mb4&parseTime=True&loc=Local

# JWT 签名密钥（生产环境务必更换为随机长字符串）
LOOPGUARD_JWT_SECRET=change-me-to-a-random-secret

# 外部访问地址（用于拼接审批链接，结尾不带斜杠）
# 分离架构下指向 nginx 前端入口（用户浏览器访问的地址），不是后端 8080
LOOPGUARD_BASE_URL=http://localhost
